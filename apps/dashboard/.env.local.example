# Required — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Required — from your GitHub OAuth App (https://github.com/settings/developers)
# Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_ID=
GITHUB_SECRET=

# Optional — defaults to http://localhost:3000 in development
NEXTAUTH_URL=http://localhost:3000

# Host `pnpm dev`: publish flux-system Postgres on localhost (dashboard connects via 127.0.0.1, not Docker DNS).
# If flux-system was created before this was set, recreate DB + API containers once (data volume is kept):
#   docker rm -f flux-5y57e70-flux-system-db flux-5y57e70-flux-system-api
# Then restart `pnpm dev`. Optional: set FLUX_DEV_POSTGRES_PASSWORD for a deterministic local password.
# FLUX_SYSTEM_POSTGRES_PUBLISH_PORT=15432
