# Next.js env layout (`pnpm --filter dashboard dev`):
#
#   .env              Optional shared defaults (gitignored). Often parallels staging/server values.
#   .env.local        Your machine — overrides .env for the same keys (gitignored).
#
# Never commit real secrets. docker/web/.env is separate — used only when flux-web runs in Docker.

# Required — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Required — GitHub OAuth App (callback: http://localhost:3000/api/auth/callback/github in dev)
GITHUB_ID=
GITHUB_SECRET=

# Required on laptop dev — pin redirects/cookies (override staging URLs from `.env` if needed):
# AUTH_URL=http://localhost:3000
# NEXTAUTH_URL=http://localhost:3000

# Host `pnpm dev` — publish flux-system Postgres to 127.0.0.1 (see `.env.local.example` for recreate note).
# Overrides automatic URL rewrite if you set it explicitly:
# FLUX_SYSTEM_DATABASE_URL=postgresql://postgres:PASSWORD@127.0.0.1:15432/postgres
# FLUX_SYSTEM_POSTGRES_PUBLISH_PORT=15432

# Optional — Stripe (leave unset to disable billing routes in dev)
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_PRO_PRICE_ID=

# Optional — Cloudflare Workers AI for the interactive Codex on /docs.
# Account ID: Cloudflare dashboard (Workers & Pages) or token account scope.
# Token: Workers AI read (restrict to account when possible). Leave blank to disable Codex AI until configured.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
