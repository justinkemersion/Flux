{
  "name": "flux",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "docker:build:gateway": "docker build -f packages/gateway/Dockerfile -t flux-gateway .",
    "docker:compose:gateway": "docker compose -f packages/gateway/docker-compose.yml up -d --build",
    "docker:compose:gateway:down": "docker compose -f packages/gateway/docker-compose.yml down",
    "docker:compose:traefik": "docker compose -f docker/traefik/docker-compose.yml up -d",
    "docker:compose:traefik:down": "docker compose -f docker/traefik/docker-compose.yml down",
    "test": "pnpm -r --if-present test",
    "check:architecture": "tsx scripts/check-architecture.ts",
    "perf:gateway:matrix": "bash perf/k6/run-matrix.sh",
    "perf:gateway:warm": "k6 run perf/k6/scenarios/warm-steady.js",
    "perf:gateway:overload": "k6 run perf/k6/scenarios/overload.js",
    "perf:gateway:summary": "node perf/k6/summarize-results.mjs",
    "perf:gateway:truth": "k6 run perf/k6/scenarios/arch-truth-test.js",
    "perf:gateway:score": "node perf/k6/score-run.mjs",
    "perf:gateway:truth-score": "bash perf/k6/run-truth-and-score.sh"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@types/node": "^20.19.4",
    "tsx": "^4.21.0"
  }
}
