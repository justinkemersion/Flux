# @flux/gateway — environment variables
#
# Copy to .env and fill in values before running `pnpm start`.
# Required fields must be set or the gateway will refuse to start.

# ── Required ─────────────────────────────────────────────────────────────────

# Direct connection string to the flux-system Postgres database.
# No Docker provisioning — must point to an already-running instance.
FLUX_SYSTEM_DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/postgres

# HS256 signing secret for gateway-minted runtime JWTs.
# Must be at least 32 characters. Rotate via deployment secret management.
FLUX_GATEWAY_JWT_SECRET=change-me-to-a-random-string-of-at-least-32-chars

# Internal (non-public) URL of the PostgREST pool.
# PostgREST is never publicly reachable — invariant 4.
FLUX_POSTGREST_POOL_URL=http://127.0.0.1:3001

# Base domain for subdomain-slug fallback resolution.
# e.g. "flux.localhost" → "myapp.flux.localhost" resolves to project slug "myapp".
# Custom domains (apex, www) are looked up in the `domains` table and don't use this.
FLUX_BASE_DOMAIN=flux.localhost

# ── Optional ─────────────────────────────────────────────────────────────────

# Redis connection string. When absent, all Redis operations are skipped (fail-open).
# REDIS_URL=redis://127.0.0.1:6379

# Gateway HTTP port. Default: 4000
# PORT=4000

# Per-tenant request limit per rate window. Default: 100
# FLUX_GATEWAY_RATE_LIMIT=100

# Rate limit window in seconds. Default: 60
# FLUX_GATEWAY_RATE_WINDOW_SEC=60

# JWT TTL in seconds (iat → exp). Default: 300 (5 minutes)
# FLUX_GATEWAY_JWT_TTL_SEC=300

# Upstream PostgREST fetch timeout in milliseconds. Default: 8000
# FLUX_POSTGREST_TIMEOUT_MS=8000
