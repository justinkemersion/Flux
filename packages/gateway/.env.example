# @flux/gateway — environment variables
#
# Copy to .env and fill in values before running `pnpm start`.
# Required fields must be set or the gateway will refuse to start.
#
# Pool secret: keep FLUX_GATEWAY_JWT_SECRET in lockstep with the pool PostgREST
# PGRST_JWT_SECRET (same byte string) for **gateway→PostgREST** HS256 tokens.
# Per-tenant `projects.jwt_secret` lives in flux-system and is **not** this value;
# it is used only to verify optional client Bearer JWTs before proxying.
#
# Liveness: GET /health (200 if the process is up; no DB/Redis checks).
# Readiness: GET /health/deep (200/503; system DB + optional Redis).
#
# Scope: Pointing FLUX_POSTGREST_POOL_URL at a single-tenant PostgREST (e.g. one
# project’s -api container) is fine for dev/prelim. It does not exercise v2
# shared-pool routing, cross-tenant isolation, or “real” v2 behavior—do not treat
# that setup as proof of v2 correctness.

# ── Required ─────────────────────────────────────────────────────────────────

# Direct connection string to the flux-system Postgres database.
# No Docker provisioning — must point to an already-running instance.
FLUX_SYSTEM_DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/postgres

# Pool HS256 secret for gateway-minted upstream JWTs (must equal PGRST_JWT_SECRET on the pool).
# Must be at least 32 characters. Not the per-project tenant signing key in `projects.jwt_secret`.
FLUX_GATEWAY_JWT_SECRET=REPLACE_THIS

# Internal (non-public) URL of the PostgREST pool.
# PostgREST is never publicly reachable — invariant 4.
# For a shared v2 pool, this is the pool’s internal base URL; a single-tenant URL is not v2.
FLUX_POSTGREST_POOL_URL=http://127.0.0.1:3001

# Base domain for subdomain-slug fallback resolution.
# e.g. "flux.localhost" → "myapp.flux.localhost" resolves to project slug "myapp".
# Custom domains (apex, www) are looked up in the `domains` table and don't use this.
FLUX_BASE_DOMAIN=flux.localhost

# ── Optional ─────────────────────────────────────────────────────────────────

# Redis connection string. When absent, all Redis operations are skipped (fail-open).
# REDIS_URL=redis://127.0.0.1:6379

# Gateway HTTP port. Default: 4000
# PORT=4000

# Docker Compose only (packages/gateway/docker-compose.yml): published host port; container uses PORT.
# GATEWAY_HOST_PORT=4000

# Per-tenant request limit per rate window. Default: 100
# FLUX_GATEWAY_RATE_LIMIT=100

# Rate limit window in seconds. Default: 60
# FLUX_GATEWAY_RATE_WINDOW_SEC=60

# JWT TTL in seconds (iat → exp). Default: 300 (5 minutes)
# FLUX_GATEWAY_JWT_TTL_SEC=300

# Upstream PostgREST fetch timeout in milliseconds. Default: 8000
# FLUX_POSTGREST_TIMEOUT_MS=15000

# Node HTTP socket timeout in milliseconds. Keep slightly above PostgREST timeout.
# Default: 9000
# FLUX_GATEWAY_SOCKET_TIMEOUT_MS=16000

# Hard concurrency cap for gateway in-flight proxy work. Default: 1000
# FLUX_GATEWAY_MAX_INFLIGHT=1000

# Enable adaptive cap controller (0=false, 1=true). Default: 0
# FLUX_GATEWAY_ADAPTIVE_INFLIGHT=0

# Adaptive limiter lower bound. Default: 100
# FLUX_GATEWAY_ADAPTIVE_MIN_INFLIGHT=100

# Adaptive limiter upper bound. Default: 2000
# FLUX_GATEWAY_ADAPTIVE_HARD_MAX_INFLIGHT=2000

# Adaptive target p95 latency in ms (control loop target). Default: 500
# FLUX_GATEWAY_ADAPTIVE_TARGET_P95_MS=500

# Additive increase step when healthy. Default: 50
# FLUX_GATEWAY_ADAPTIVE_UP_STEP=50

# Multiplicative decrease factor when stressed. Default: 0.9
# FLUX_GATEWAY_ADAPTIVE_DOWN_FACTOR=0.9

# Rolling sample size for p95 estimation. Default: 200
# FLUX_GATEWAY_ADAPTIVE_SAMPLE_SIZE=200

# Adaptive control loop interval in ms. Default: 1000
# FLUX_GATEWAY_ADAPTIVE_TICK_MS=1000
