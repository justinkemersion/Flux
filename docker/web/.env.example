# Copy to `.env` next to docker-compose.yml on the host running flux-web.
# `.env*` is gitignored — never commit real values.

# GID of the host `docker` group (must match /var/run/docker.sock). Example: stat -c '%g' /var/run/docker.sock
# Defaults to 996 in docker-compose.yml if unset.
# DOCKER_GID=996

# Auth.js session signing secret. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# GitHub OAuth App credentials.
# Production callback: https://flux.vsl-base.com/api/auth/callback/github
GITHUB_ID=
GITHUB_SECRET=

# Shared secret for POST /api/projects/[slug]/activity (used by @flux/sdk activity option).
# Generate with: openssl rand -hex 32
FLUX_ACTIVITY_SECRET=

# Optional — Stripe billing (leave unset to disable checkout/webhook routes):
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_PRO_PRICE_ID=
# STRIPE_WEBHOOK_SECRET=
