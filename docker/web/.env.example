# Copy to `.env` next to docker-compose.yml on the host running flux-web.
# `.env*` is gitignored — never commit real values.

# GID of the host `docker` group (should match `stat -c '%g' /var/run/docker.sock`).
# Used for Compose `group_add` and as override for entrypoint `setpriv` when the socket is absent.
# flux-web-entrypoint.sh normally reads the bind-mounted socket’s group automatically so EACCES survives
# docker reinstalls / GID drift; set DOCKER_GID when you want an explicit pin or when stat is unavailable.
# Defaults to 996 in docker-compose.yml if unset.
# DOCKER_GID=996

# Auth.js session signing secret. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# GitHub OAuth App credentials.
# Production callback: https://flux.vsl-base.com/api/auth/callback/github
GITHUB_ID=
GITHUB_SECRET=

# Shared secret for POST /api/projects/[slug]/activity (used by @flux/sdk activity option).
# Generate with: openssl rand -hex 32
FLUX_ACTIVITY_SECRET=

# Shared cluster Postgres URL used by v2_shared provisioning (engine-v2 bootstrap path).
# Required when any project uses mode=v2_shared.  flux-web must be on the flux-v2-shared
# Docker network (see docker/web/docker-compose.yml) for this hostname to resolve.
# Generate the password from docker/v2-shared/.env SHARED_POSTGRES_PASSWORD.
FLUX_SHARED_POSTGRES_URL=postgresql://postgres:CHANGE_ME_STRONG_DB_PASSWORD@flux-postgres-v2:5432/postgres

# Optional — recommended in production. Mesh / tenant HTTP probes (fleet monitor, v2 “start”)
# call this URL and send `Host: api.<slug>.<hash>.<domain>`. Use when direct `https://` probes
# from inside flux-web fail (TLS / wildcard cert depth, DNS) while the gateway is healthy.
# FLUX_TENANT_PROBE_GATEWAY_URL=http://flux-node-gateway:4000

# Optional — v1_dedicated backup files on disk (defaults: /srv/flux/backups and .../backups-offsite).
# docker/web/docker-compose.yml mounts named volumes there; the image entrypoint chowns them for user `nextjs`.
# For testing you can keep “offsite” on the same machine (different directory) to exercise replication without a remote mount.
# FLUX_BACKUPS_LOCAL_DIR=/srv/flux/backups
# FLUX_BACKUPS_OFFSITE_DIR=/srv/flux/backups-offsite

# Optional — Docker image for `flux backup verify` disposable Postgres (pg_restore must be >= pg_dump major).
# flux-web ships postgresql17-client; v2_shared dumps use custom format 1.16, which pg_restore 16 rejects.
# Default in code: postgres:17-alpine (reads both 1.16 and older v1 dumps). Pin when you want a fixed digest.
# FLUX_BACKUP_VERIFY_POSTGRES_IMAGE=postgres:17-alpine

# Optional — Stripe billing (leave unset to disable checkout/webhook routes):
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_PRO_PRICE_ID=
# STRIPE_WEBHOOK_SECRET=

# Optional — Cloudflare Workers AI for the interactive Codex on /docs (Llama 3 8B).
# Token needs Workers AI (read) for the account. Leave blank until configured.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
