# Flux v2 shared stack environment
#
# Copy this to `.env` on the remote host and fill secrets:
#   cp docker/v2-shared/.env.example docker/v2-shared/.env
#
# Then load it before deploy:
#   set -a && source docker/v2-shared/.env && set +a
#   ./bin/deploy-v2-shared.sh
#
# Required by bin/deploy-v2-shared.sh:
#   SHARED_POSTGRES_PASSWORD
#   PGB_BACKEND_PASSWORD
#   PGRST_DB_PASSWORD
#   FLUX_GATEWAY_JWT_SECRET

# ---------------------------------------------------------------------------
# Required secrets
# ---------------------------------------------------------------------------

# Shared Postgres superuser password (postgres-v2 container)
SHARED_POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# PgBouncer backend password for POSTGRESQL_USERNAME
# Keep equal to SHARED_POSTGRES_PASSWORD when using backend user "postgres".
PGB_BACKEND_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# PostgREST DB password for PGRST_DB_USER
# Keep equal to SHARED_POSTGRES_PASSWORD when PGRST_DB_USER is "authenticator"
# and that role's password is configured to match.
PGRST_DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# Must byte-match gateway FLUX_GATEWAY_JWT_SECRET.
# PostgREST verifies runtime JWTs signed by gateway using this value.
FLUX_GATEWAY_JWT_SECRET=CHANGE_ME_MIN_32_CHARS

# ---------------------------------------------------------------------------
# Optional database/user settings
# ---------------------------------------------------------------------------

SHARED_POSTGRES_USER=postgres
SHARED_POSTGRES_DB=postgres

PGB_BACKEND_USER=postgres
PGB_DATABASE=postgres
PGB_MAX_CLIENT_CONN=1000
PGB_DEFAULT_POOL_SIZE=100
PGB_AUTH_TYPE=scram-sha-256
PGB_ADMIN_USERS=postgres

PGRST_DB_USER=authenticator
PGRST_DB_NAME=postgres
PGRST_DB_ANON_ROLE=authenticator
# PGRST_DB_SCHEMAS is overridden at runtime by the pre-config hook.
# Leave as "public" here; flux_postgrest_config() populates the real list.
PGRST_DB_SCHEMAS=public
PGRST_DB_POOL=50
# PostgREST server-side hooks — installed by bootstrapSharedCluster() at deploy time.
PGRST_DB_PRE_CONFIG=public.flux_postgrest_config
PGRST_DB_PRE_REQUEST=public.flux_set_tenant_context

# ---------------------------------------------------------------------------
# Optional deploy-script overrides
# ---------------------------------------------------------------------------

# FLUX_DEPLOY_GIT_SYNC=1
# FLUX_DEPLOY_PRUNE_BUILDER=1
# FLUX_V2_COMPOSE_FILE=docker/v2-shared/docker-compose.yml
# FLUX_V2_POSTGRES_CONTAINER=flux-postgres-v2
# FLUX_V2_PGBOUNCER_CONTAINER=flux-pgbouncer
# FLUX_V2_POSTGREST_CONTAINER=flux-postgrest-pool
# FLUX_V2_POSTGREST_URL=http://flux-postgrest-pool:3000/
# FLUX_V2_PROBE_CONTAINER=flux-node-gateway
# FLUX_V2_SKIP_POSTGREST_PROBE=0
